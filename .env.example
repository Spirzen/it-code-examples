# === Продакшен code.spirzen.ru (custom domain) ===
# Обязательно для CI и deploy.bat:
IT_CODE_EXAMPLES_SITE=https://code.spirzen.ru
IT_CODE_EXAMPLES_BASE=/

# === Локальная разработка ===
# По умолчанию astro dev на :4321, BASE=/ — переменные не нужны.
# Другой порт:
# IT_CODE_EXAMPLES_SITE=http://localhost:4322

# === УСТАРЕЛО: только github.io/it-code-examples/ без custom domain ===
# Не использовать для code.spirzen.ru — сломает CSS и /e/… URL.
# IT_CODE_EXAMPLES_SITE=https://spirzen.github.io
# IT_CODE_EXAMPLES_BASE=/it-code-examples/
