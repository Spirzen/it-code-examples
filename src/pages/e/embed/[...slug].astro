---
import EmbedLayout from '@/layouts/EmbedLayout.astro';
import ExampleViewer from '@/components/ExampleViewer.astro';
import {loadCatalog, loadExampleBySlug} from '@/lib/examples';

export function getStaticPaths() {
  return loadCatalog().map((entry) => ({
    params: {slug: entry.slug},
    props: {slug: entry.slug},
  }));
}

const {slug} = Astro.props;
const example = loadExampleBySlug(slug)!;

const pageTitle = `${example.title} — embed`;
---

<EmbedLayout title={pageTitle}>
  <ExampleViewer example={example} />
</EmbedLayout>
