---
import {Code} from 'astro:components';
import {getLanguageLabel} from '@/lib/languages';

interface Props {
  code: string;
  lang: string;
  filename?: string;
  rawContent?: string;
}

const {code, lang, filename, rawContent} = Astro.props;
const source = rawContent ?? code;
const langLabel = getLanguageLabel(lang);
---

<div
  class="code-block"
  data-filename={filename}
  data-lang={lang}
  data-lang-label={langLabel}
  data-raw={source}
>
  <div class="code-block__toolbar">
    <div class="code-block__meta">
      <span class="code-block__lang">{langLabel}</span>
      {filename && <span class="code-block__name">{filename}</span>}
    </div>
    <div class="code-block__actions">
      <button type="button" class="code-block__btn" data-copy aria-label="Копировать код">
        Копировать
      </button>
      <button type="button" class="code-block__btn" data-fullscreen aria-label="На весь экран">
        На весь экран
      </button>
    </div>
  </div>
  <div class="code-block__views">
    <div class="code-block__view code-block__view--dark">
      <Code code={code} lang={lang} theme="github-dark" />
    </div>
    <div class="code-block__view code-block__view--light">
      <Code code={code} lang={lang} theme="github-light" />
    </div>
  </div>
</div>
