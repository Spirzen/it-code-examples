Процедура КнопкаВыводаНажатие(Кнопка)
    
    Текст = ВводСтроки("Введите ваше приветствие", , "Текст");
    
    Если Не ПустаяСтрока(Текст) Тогда
        
        Реквизит.ТекстПриветствия = Текст;
        
        Записать();
        
        Сообщить("Документ сохранен. Сообщение: " + Текст);
        
    КонецЕсли;
    
КонецПроцедуры
